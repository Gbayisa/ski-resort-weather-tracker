# Base URL for the backend API.
# Leave blank when running locally with `npm run dev` (Vite proxy handles it)
# OR when deploying the unified single-service build on Render (the Express
# backend serves the frontend, so relative /api requests work automatically).
#
# Only set this when the frontend is deployed as a standalone static site
# on a DIFFERENT domain from the backend. In that case set it to:
#   VITE_API_BASE_URL=https://<your-backend>.onrender.com/api
# Note: the value MUST end with /api — it is compiled into the static bundle
# at build time and cannot be changed after the build.
VITE_API_BASE_URL=

# ── Google AdSense ────────────────────────────────────────────────────────────
# Set all three variables to enable live ads. Leave blank to show placeholders.
#
# VITE_ADSENSE_CLIENT  – Your AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX).
#                        Found in AdSense › Account › Account information.
#
# VITE_ADSENSE_SLOT_TOP    – Ad-unit slot ID for the leaderboard above results.
# VITE_ADSENSE_SLOT_BOTTOM – Ad-unit slot ID for the banner below results.
#                        Both slot IDs are found in AdSense › Ads › By ad unit.
#
# IMPORTANT – compliance notes:
#   • Sites with ads are considered COMMERCIAL use by Open-Meteo. A commercial
#     API license is required: https://open-meteo.com/en/pricing
#   • For visitors in the EU / EEA / UK / Switzerland you must integrate a
#     Google-certified Consent Management Platform (CMP) BEFORE serving
#     personalised ads to comply with GDPR / TCF v2.x requirements.
#     See: https://support.google.com/adsense/answer/13554116
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT_TOP=
VITE_ADSENSE_SLOT_BOTTOM=
